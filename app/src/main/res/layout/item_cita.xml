<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/txt_item_especialidad"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Cardiología"
                android:textColor="#2C3E50"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txt_item_estado"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Agendada"
                android:textSize="12sp"
                android:textColor="#2ECC71"
                android:textStyle="bold"
                android:background="@drawable/bg_rounded"
                android:paddingHorizontal="8dp"
                android:paddingVertical="2dp" />
        </LinearLayout>

        <TextView
            android:id="@+id/txt_item_doctor"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Dr. Carlos López"
            android:textColor="#7F8C8D"
            android:textSize="14sp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginVertical="8dp"
            android:background="#ECF0F1" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/txt_item_fecha"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="📅 15/10/2023"
                android:textColor="#34495E"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/txt_item_hora"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🕒 09:30"
                android:textColor="#34495E"
                android:textSize="14sp" />
        </LinearLayout>

        <!-- Botones de Acción -->
        <LinearLayout
            android:id="@+id/layout_acciones"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="16dp"
            android:gravity="end">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_cancelar_cita"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Cancelar"
                android:textColor="#E74C3C"
                app:strokeColor="#E74C3C" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_reagendar_cita"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Reagendar"
                android:backgroundTint="#3498DB"
                android:textColor="@android:color/white"
                android:layout_marginStart="8dp" />
        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>
